# ============================================================================
# norush — environment variables
# ============================================================================
# Copy to `.env` and fill in what you need. `.env` is gitignored.
# Values below marked (required) must be set; others are optional.
# ============================================================================

# --- Database ---------------------------------------------------------------
# The default (unset) matches the `postgres` service on the docker-compose
# network — leave unset when running `pnpm dev` / `docker compose up`.
# Set this only when running the app outside the compose network (e.g. local
# `pnpm build && node packages/web/dist/index.js` against `pnpm db:up`):
#   DATABASE_URL=postgres://postgres:dev@localhost:5432/norush

# --- Core secrets -----------------------------------------------------------
# (required) Master key for the API key vault. 32+ chars. Rotate in production.
NORUSH_MASTER_KEY=dev-master-key-change-me

# --- Provider API keys ------------------------------------------------------
# (optional, but the worker warns on startup if neither is set — it needs at
# least one provider key to submit batches for any user that hasn't supplied
# their own key via the UI)
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Engine tuning ----------------------------------------------------------
# All optional. Defaults shown. Applies to both the web engine and the worker
# (the worker also reads the retention settings below).
# NORUSH_FLUSH_INTERVAL_MS=300000   # how often the worker auto-flushes queued requests (5 min)
# NORUSH_POLL_INTERVAL_MS=60000     # how often the worker polls provider batch status (1 min)
# NORUSH_DELIVERY_INTERVAL_MS=5000  # how often the worker retries webhook delivery (5 s)
# NORUSH_MAX_REQUESTS=1000          # max requests collected per flush cycle

# --- Retention (worker only) ------------------------------------------------
# NORUSH_RETENTION_DEFAULT=7d              # default retention policy ('on_ack' or 'Nd')
# NORUSH_RETENTION_HARD_CAP_DAYS=90       # hard cap; users cannot exceed this
# NORUSH_RETENTION_INTERVAL_MS=3600000    # how often the retention sweep runs (1 hr)

# --- Web server -------------------------------------------------------------
# (optional) Public URL of the web server. Used by SvelteKit for CSRF origin
# checks and absolute-URL generation. Must match the URL in your browser.
ORIGIN=http://localhost:3000

# (optional) Node environment. Leave as `development` locally; set to
# `production` only for real deploys.
NODE_ENV=development

# --- Authentication (WorkOS AuthKit) ----------------------------------------
# (optional) Set to `1` to skip WorkOS entirely in development and sign in
# as a synthetic `dev-user` on every request. Ignored when NODE_ENV=production.
# Use this to kick the tyres without provisioning a WorkOS app.
NORUSH_DEV_AUTH_BYPASS=1

# (required unless NORUSH_DEV_AUTH_BYPASS=1)
# Create a WorkOS AuthKit application and paste the values here.
# Register http://localhost:3000/auth/callback as a redirect URI in WorkOS.
# WORKOS_API_KEY=sk_test_...
# WORKOS_CLIENT_ID=client_...
# WORKOS_COOKIE_PASSWORD=a-random-32-plus-character-secret-xxxxxxxxx
# WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback
