{
  "name": "norush",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint .",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --write . --log-level warn",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose stop postgres",
    "worker:up": "docker compose up -d worker",
    "worker:down": "docker compose stop worker",
    "host:dev": "pnpm worker:up && pnpm --filter @norush/web dev",
    "docker:build": "docker compose build",
    "dev:start": "docker compose up -d",
    "dev:up": "docker compose up --build",
    "dev:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "prettier": "^3.8.3",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
