{
  "name": "@norush/core",
  "version": "0.0.0",
  "description": "Deferred LLM batch execution engine — trade immediacy for 50% cost savings via Anthropic and OpenAI batch APIs.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./prometheus": {
      "types": "./dist/telemetry/prometheus.d.ts",
      "import": "./dist/telemetry/prometheus.js"
    },
    "./opentelemetry": {
      "types": "./dist/telemetry/opentelemetry.d.ts",
      "import": "./dist/telemetry/opentelemetry.js"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "bin": {
    "norush-rotate-key": "./dist/cli/rotate-key.js"
  },
  "files": [
    "dist",
    "migrations",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    },
    "types": "./dist/index.d.ts"
  },
  "keywords": [
    "llm",
    "batch",
    "deferred",
    "anthropic",
    "claude",
    "openai",
    "ai",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/norush-ai/norush",
    "directory": "packages/core"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.86.1",
    "openai": "^6.34.0",
    "postgres": "^3.4.5",
    "ulidx": "^2.4.1"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "prom-client": "^15.1.3"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
